[internationalization]

locale/translations=PackedStringArray("res://GameData/Translations/translations.de.translation", "res://GameData/Translations/translations.en.translation", "res://GameData/Translations/translations.es.translation", "res://GameData/Translations/translations.fr.translation", "res://GameData/Translations/translations.it.translation", "res://GameData/Translations/translations.ja.translation", "res://GameData/Translations/translations.ko.translation", "res://GameData/Translations/translations.pl.translation", "res://GameData/Translations/translations.pt.translation", "res://GameData/Translations/translations.ru.translation", "res://GameData/Translations/translations.tr.translation", "res://GameData/Translations/translations.zh.translation")
